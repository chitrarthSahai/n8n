{
  "name": "Terraform & Azure",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/azure-cli:1": { "version": "latest" }
  },
  "mounts": [
    "source=codespaces-az-cli,target=/home/vscode/.azure,type=volume"
  ],
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": ["hashicorp.terraform", "ms-vscode.azurecli"]
    }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.azure"
}
